# Copy this file to .env and fill in the values from your Supabase project
# (Project Settings -> API in the Supabase dashboard).
#
# Both the plain and VITE_-prefixed versions of the URL/publishable key are
# required: the plain versions are used by server-side code (SSR, server
# functions, middleware), and the VITE_-prefixed versions are inlined into
# the browser bundle by Vite so client-side code (e.g. the login/signup
# form) can reach Supabase. Login/signup will fail with "Failed to fetch"
# if the VITE_ versions are missing.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-side only. Never expose this to the browser. Required for admin
# operations (src/integrations/supabase/client.server.ts) that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
